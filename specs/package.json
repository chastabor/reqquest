{
  "name": "@reqquest/specs",
  "version": "0.1.0",
  "type": "module",
  "description": "ReqQuest spec-driven project generator. Reads a YAML spec from specs/requirements/ and emits a runnable downstream project under demos/src/<project>/ and ui/src/local/<project>/.",
  "exports": {
    ".": "./dist/index.js"
  },
  "types": "./dist/index.d.ts",
  "bin": {
    "reqquest-gen": "./dist/cli.js"
  },
  "scripts": {
    "build": "rm -rf dist/* && tsc",
    "gen": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test"
  },
  "license": "MIT",
  "devDependencies": {
    "@stylistic/eslint-plugin": "^4.0.0",
    "@types/node": "^24.3.1",
    "eslint-config-love": "^119.0.0",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "prettier": "^3.3.0",
    "ts-morph": "^24.0.0",
    "typescript": "^5.6.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "files": [
    "dist"
  ]
}
